# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5434/time_cafe_shared?schema=public"

# Keycloak Configuration
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=time-cafe-shared
KEYCLOAK_CLIENT_ID=backend-shared-api
KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# MinIO / S3 Storage Configuration
# Куда Nest ходит за S3 API (в Docker часто http://minio:9000 или http://host.docker.internal:9000).
STORAGE_ENDPOINT=http://localhost:9000
# Куда браузер/телефон открывают presigned URL (Host в подписи AWS). Если не задано — как STORAGE_ENDPOINT;
# при STORAGE_ENDPOINT=localhost: подставляется хост из FRONTEND_URL (если это частный IP), иначе первая LAN IPv4.
# На ПК с несколькими сетевухами «первая» IP часто не Wi‑Fi (например 192.168.61.x вместо 192.168.35.x) — тогда обязательно:
# STORAGE_PUBLIC_ENDPOINT=http://192.168.35.4:9000
# либо префикс нужной подсети:
# STORAGE_LAN_PREFER_PREFIX=192.168.35
STORAGE_PUBLIC_ENDPOINT=
STORAGE_LAN_PREFER_PREFIX=
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false

# Application Configuration
PORT=3000
NODE_ENV=development

# Origin веб-клиента для CORS. Для presigned MinIO при localhost STORAGE_ENDPOINT: если здесь частный IP
# (например http://192.168.35.4:3001), хост подставится в URL файлов :9000 на том же IP.
FRONTEND_URL=http://localhost:3001
