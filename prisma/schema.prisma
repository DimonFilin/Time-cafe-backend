generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WorkerAccount {
  id                   String            @id @default(uuid())
  keycloakId           String
  email                String
  firstName            String
  lastName             String
  role                 WorkerRole
  shiftStatus          WorkerShiftStatus @default(OFF_SHIFT)
  brandId              String?
  cafeId               String?
  deletedAt            DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  activityLogs         ActivityLog[]
  taskCompletions      TaskCompletion[]
  createdTaskTemplates TaskTemplate[]
  chatMessages         OrderChatMessage[]
  chatReadStates       OrderChatReadState[]
  chatTypingStates     OrderChatTypingState[]
  brand                Brand?            @relation(fields: [brandId], references: [id])
  cafe                 Cafe?             @relation(fields: [cafeId], references: [id])

  @@map("worker_accounts")
}

model User {
  id           String        @id @default(uuid())
  keycloakId   String
  email        String
  firstName    String
  lastName     String
  phone        String?
  avatar       String?
  balance      Decimal       @default(0) @db.Decimal(10, 2)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  bookings     Appointment[]
  orders       Order[]
  paymentCards PaymentCard[]
  reviews      Review[]
  transactions Transaction[]
  orderChats   OrderChat[]
  chatMessages OrderChatMessage[]
  chatReadStates OrderChatReadState[]
  chatTypingStates OrderChatTypingState[]

  @@map("users")
}

model Brand {
  id              String          @id @default(uuid())
  name            String
  description     String?
  logo            String?
  primaryColor    String?         @default("#000000")
  secondaryColor  String?
  accentColor     String?
  backgroundColor String?
  textColor       String?
  fontFamily      String?
  favicon         String?
  bannerImage     String?
  backgroundImage String?
  website         String?
  phone           String?
  email           String?
  address         String?
  status          BrandStatus     @default(PENDING)
  isVerified      Boolean         @default(false)
  verifiedAt      DateTime?
  settings        Json?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  activityLogs    ActivityLog[]
  apiKeys         BrandApiKey[]
  legalDocuments  BrandDocument[]
  cafes           Cafe[]
  workerAccounts  WorkerAccount[]
  orderChats      OrderChat[]

  @@map("brands")
}

model Region {
  id        String   @id @default(uuid())
  name      String
  country   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cafes     Cafe[]

  @@map("regions")
}

model Cafe {
  id             String          @id @default(uuid())
  name           String
  description    String?
  address        String
  city           String
  street         String?
  latitude       Float
  longitude      Float
  photos         String[]
  rating         Float?          @default(0)
  reviewsCount   Int             @default(0)
  brandId        String
  regionId       String
  cafeApiUrl     String?
  openingHours   Json?
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  activityLogs   ActivityLog[]
  appointments   Appointment[]
  brand          Brand           @relation(fields: [brandId], references: [id])
  region         Region          @relation(fields: [regionId], references: [id])
  orders         Order[]
  menuCategories CafeMenuCategory[]
  menuItems      CafeMenuItem[]
  reviews        Review[]
  taskTemplates  TaskTemplate[]
  workerAccounts WorkerAccount[]
  orderChats     OrderChat[]
  chatSettings   Json?

  @@map("cafes")
}

model CafeMenuCategory {
  id          String   @id @default(uuid())
  cafeId      String
  key         String
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cafe  Cafe           @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  items CafeMenuItem[]

  @@unique([cafeId, key])
  @@index([cafeId, sortOrder])
  @@map("cafe_menu_categories")
}

model CafeMenuItem {
  id          String   @id @default(uuid())
  cafeId      String
  categoryId  String
  key         String
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("BYN")
  photoUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cafe     Cafe             @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  category CafeMenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([cafeId, key])
  @@index([cafeId, categoryId, sortOrder])
  @@map("cafe_menu_items")
}

model Order {
  id                 String        @id @default(uuid())
  orderNumber        String        @unique
  userId             String
  cafeId             String
  appointmentId      String?
  status             OrderStatus   @default(PENDING)
  totalAmount        Decimal       @db.Decimal(10, 2)
  deliveryType       DeliveryType  @default(IN_CAFE)
  deliveryAddress    String?
  contactPhone       String?
  notes              String?
  paymentMethod      PaymentMethod @default(CARD)
  paidAt             DateTime?
  confirmedAt        DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  items              OrderItem[]
  appointment        Appointment?  @relation(fields: [appointmentId], references: [id])
  cafe               Cafe          @relation(fields: [cafeId], references: [id])
  user               User          @relation(fields: [userId], references: [id])
  review             Review?
  transactions       Transaction[]
  chat               OrderChat?

  @@index([userId, createdAt])
  @@index([cafeId, status])
  @@index([orderNumber])
  @@index([appointmentId])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  itemName   String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  totalPrice Decimal  @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

model Review {
  id         String    @id @default(uuid())
  userId     String
  cafeId     String
  orderId    String?   @unique
  rating     Float
  comment    String?
  pros       String[]
  cons       String[]
  photos     String[]
  isVerified Boolean   @default(false)
  verifiedAt DateTime?
  verifiedBy String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  cafe       Cafe      @relation(fields: [cafeId], references: [id])
  order      Order?    @relation(fields: [orderId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@index([cafeId, createdAt])
  @@index([userId, cafeId])
  @@index([orderId])
  @@map("reviews")
}

model Appointment {
  id            String   @id @default(uuid())
  userId        String
  cafeId        String
  dateTime      DateTime
  duration      Int
  status        String   @default("pending")
  qrCode        String?  @unique
  totalAmount   Decimal? @db.Decimal(10, 2)
  paymentMethod String?
  transactionId String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cafe          Cafe     @relation(fields: [cafeId], references: [id])
  user          User     @relation(fields: [userId], references: [id])
  orders        Order[]

  @@map("appointments")
}

model PaymentCard {
  id            String        @id @default(uuid())
  userId        String
  last4Digits   String
  cardType      String
  expiryMonth   Int
  expiryYear    Int
  providerToken String?
  isDefault     Boolean       @default(false)
  isActive      Boolean       @default(true)
  holderName    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  user          User          @relation(fields: [userId], references: [id])
  transactions  Transaction[]

  @@index([userId, deletedAt])
  @@map("payment_cards")
}

model Transaction {
  id                    String            @id @default(uuid())
  userId                String
  type                  TransactionType
  status                TransactionStatus @default(PENDING)
  amount                Decimal           @db.Decimal(10, 2)
  currency              String            @default("BYN")
  orderId               String?
  cardId                String?
  provider              String?
  providerTransactionId String?
  description           String?
  metadata              Json?
  retryCount            Int               @default(0)
  maxRetries            Int               @default(3)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  card                  PaymentCard?      @relation(fields: [cardId], references: [id])
  order                 Order?            @relation(fields: [orderId], references: [id])
  user                  User              @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
  @@index([orderId])
  @@map("transactions")
}

model BrandDocument {
  id               String       @id @default(uuid())
  brandId          String
  type             DocumentType
  name             String
  fileUrl          String
  fileType         String?
  fileSize         Int?
  uploadedAt       DateTime     @default(now())
  verifiedAt       DateTime?
  verifiedBy       String?
  isVerified       Boolean      @default(false)
  verificationNote String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  brand            Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@map("brand_documents")
}

model BrandApiKey {
  id          String    @id @default(uuid())
  brandId     String
  name        String
  keyHash     String    @unique
  prefix      String
  permissions String[]
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  brand       Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId, isActive])
  @@index([keyHash])
  @@map("brand_api_keys")
}

model SystemSettings {
  id        String   @id @default("system")
  settings  Json
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("system_settings")
}

model ActivityLog {
  id           String           @id @default(uuid())
  workerId     String
  workerEmail  String
  workerRole   WorkerRole
  brandId      String?
  cafeId       String?
  action       ActivityAction
  category     ActivityCategory
  severity     LogSeverity      @default(INFO)
  resourceType String
  resourceId   String?
  details      Json?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  endpoint     String?
  method       String?
  statusCode   Int?
  duration     Int?
  createdAt    DateTime         @default(now())
  brand        Brand?           @relation(fields: [brandId], references: [id])
  cafe         Cafe?            @relation(fields: [cafeId], references: [id])
  worker       WorkerAccount    @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, createdAt(sort: Desc)])
  @@index([brandId, createdAt(sort: Desc)])
  @@index([cafeId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([category, createdAt(sort: Desc)])
  @@index([severity, createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@map("activity_logs")
}

model TaskTemplate {
  id                String             @id @default(uuid())
  cafeId            String
  title             String
  description       String?
  category          TaskCategory
  priority          TaskPriority
  requiresPhoto     Boolean            @default(false)
  requiresComment   Boolean            @default(false)
  estimatedMinutes  Int?
  assignmentType    TaskAssignmentType
  assignedWorkerIds String[]
  assignedRoles     WorkerRole[]
  isActive          Boolean            @default(true)
  daysOfWeek        Int[]
  createdById       String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  completions       TaskCompletion[]
  cafe              Cafe               @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  createdBy         WorkerAccount      @relation(fields: [createdById], references: [id])

  @@index([cafeId])
  @@index([cafeId, isActive])
  @@index([cafeId, category])
  @@map("task_templates")
}

model TaskCompletion {
  id              String        @id @default(uuid())
  templateId      String
  workerId        String
  completedAt     DateTime      @default(now())
  completionDate  DateTime
  photoUrl        String?
  comment         String?
  durationMinutes Int?
  template        TaskTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  worker          WorkerAccount @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([templateId, workerId, completionDate])
  @@index([templateId, completionDate])
  @@index([workerId, completionDate])
  @@index([completionDate])
  @@map("task_completions")
}

model OrderChat {
  id                   String                 @id @default(uuid())
  orderId              String                 @unique
  cafeId               String
  userId               String
  brandId              String?
  isEnabled            Boolean                @default(true)
  notificationMode     ChatNotificationMode   @default(ALL_WORKERS)
  notificationRoles    WorkerRole[]
  notificationWorkerIds String[]
  theme                Json?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  order                Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cafe                 Cafe                   @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand                Brand?                 @relation(fields: [brandId], references: [id], onDelete: SetNull)
  messages             OrderChatMessage[]
  readStates           OrderChatReadState[]
  typingStates         OrderChatTypingState[]

  @@index([cafeId, updatedAt(sort: Desc)])
  @@index([brandId, updatedAt(sort: Desc)])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("order_chats")
}

model OrderChatMessage {
  id             String             @id @default(uuid())
  chatId          String
  orderId         String
  cafeId          String
  authorType      ChatAuthorType
  authorUserId    String?
  authorWorkerId  String?
  messageType     ChatMessageType   @default(TEXT)
  text            String?
  isDeleted       Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  chat            OrderChat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  authorUser      User?              @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  authorWorker    WorkerAccount?     @relation(fields: [authorWorkerId], references: [id], onDelete: SetNull)
  attachments     OrderChatAttachment[]
  readStates      OrderChatReadState[]

  @@index([chatId, createdAt])
  @@index([orderId, createdAt])
  @@index([cafeId, createdAt])
  @@map("order_chat_messages")
}

model OrderChatAttachment {
  id          String                @id @default(uuid())
  chatId       String
  messageId    String?
  bucket       String
  path         String
  url          String
  mimeType     String
  size         Int
  status       ChatAttachmentStatus @default(UPLOADED)
  sortOrder    Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  message      OrderChatMessage?    @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, sortOrder])
  @@index([chatId, createdAt])
  @@map("order_chat_attachments")
}

model OrderChatReadState {
  id                String            @id @default(uuid())
  chatId             String
  userId             String?
  workerId           String?
  unreadCount        Int               @default(0)
  lastReadMessageId  String?
  lastReadAt         DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  chat               OrderChat         @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user               User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  worker             WorkerAccount?    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  lastReadMessage    OrderChatMessage? @relation(fields: [lastReadMessageId], references: [id], onDelete: SetNull)

  @@unique([chatId, userId])
  @@unique([chatId, workerId])
  @@index([chatId, unreadCount])
  @@map("order_chat_read_states")
}

model OrderChatTypingState {
  id         String          @id @default(uuid())
  chatId      String
  userId      String?
  workerId    String?
  expiresAt   DateTime
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  chat        OrderChat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user        User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  worker      WorkerAccount? @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([chatId, expiresAt])
  @@map("order_chat_typing_states")
}

enum WorkerRole {
  SYSTEM_ADMIN
  BRAND_ADMIN
  CAFE_ADMIN
  WORKER
}

enum WorkerShiftStatus {
  ON_SHIFT
  OFF_SHIFT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum DeliveryType {
  IN_CAFE
  TAKEOUT
  DELIVERY
}

enum PaymentMethod {
  CARD
  BALANCE
  CASH
}

enum TransactionType {
  PAYMENT
  REFUND
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ActivityAction {
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  TOKEN_REFRESH
  CREATE
  UPDATE
  DELETE
  BULK_UPDATE
  BULK_DELETE
  VIEW_LIST
  VIEW_DETAIL
  VIEW_REPORT
  EXPORT_DATA
  PAGE_VIEW
  MODAL_OPEN
  MODAL_CLOSE
  TAB_SWITCH
  UPDATE_SETTINGS
  UPDATE_PERMISSIONS
  FILE_UPLOAD
  FILE_DELETE
  PAYMENT_PROCESS
}

enum ActivityCategory {
  AUTH
  DATA
  VIEW
  CONFIG
  FINANCIAL
  SECURITY
}

enum LogSeverity {
  INFO
  WARNING
  CRITICAL
}

enum BrandStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum DocumentType {
  REGISTRATION
  LICENSE
  CONTRACT
  TAX_CERTIFICATE
  BANK_STATEMENT
  OTHER
}

enum TaskCategory {
  OPENING
  SHIFT
  CLOSING
  GENERAL
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum TaskAssignmentType {
  ALL_WORKERS
  SPECIFIC_WORKERS
  ROLE_BASED
}

enum ChatNotificationMode {
  ALL_WORKERS
  ROLE_BASED
  SPECIFIC_WORKERS
}

enum ChatAuthorType {
  USER
  WORKER
}

enum ChatMessageType {
  TEXT
  IMAGE
  MIXED
  SYSTEM
}

enum ChatAttachmentStatus {
  UPLOADING
  UPLOADED
  FAILED
}
