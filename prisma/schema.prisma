generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkerRole {
  SYSTEM_ADMIN
  BRAND_ADMIN
  CAFE_ADMIN
  WORKER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum DeliveryType {
  IN_CAFE
  TAKEOUT
  DELIVERY
}

enum PaymentMethod {
  CARD
  BALANCE
  CASH
}

enum TransactionType {
  PAYMENT // Платеж картой
  REFUND // Возврат средств
}

enum TransactionStatus {
  PENDING // Ожидает обработки
  PROCESSING // В процессе
  COMPLETED // Успешно завершена
  FAILED // Ошибка
  CANCELLED // Отменена
}

enum BrandStatus {
  PENDING // Ожидает проверки
  ACTIVE // Активен
  SUSPENDED // Приостановлен
  REJECTED // Отклонен
}

enum DocumentType {
  REGISTRATION // Свидетельство о регистрации
  LICENSE // Лицензия на деятельность
  CONTRACT // Договор с платформой
  TAX_CERTIFICATE // Справка из налоговой
  BANK_STATEMENT // Выписка из банка
  OTHER // Другое
}

model WorkerAccount {
  id         String     @id @default(uuid())
  keycloakId String
  email      String
  firstName  String
  lastName   String
  role       WorkerRole
  brandId    String?
  brand      Brand?     @relation(fields: [brandId], references: [id])
  cafeId     String?
  cafe       Cafe?      @relation(fields: [cafeId], references: [id])
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("worker_accounts")
}

model User {
  id         String    @id @default(uuid())
  keycloakId String
  email      String
  firstName  String
  lastName   String
  phone      String?
  avatar     String?
  balance    Decimal   @default(0) @db.Decimal(10, 2)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  orders       Order[]
  reviews      Review[]
  bookings     Appointment[]
  paymentCards PaymentCard[]
  transactions Transaction[]

  @@map("users")
}

model Brand {
  id           String  @id @default(uuid())
  name         String
  description  String?
  logo         String?
  primaryColor String? @default("#000000")

  // Customization
  secondaryColor  String?
  accentColor     String?
  backgroundColor String?
  textColor       String?
  fontFamily      String?

  // Media
  favicon         String?
  bannerImage     String?
  backgroundImage String?

  // Contact information
  website String?
  phone   String?
  email   String?
  address String?

  // Status and verification
  status     BrandStatus @default(PENDING)
  isVerified Boolean     @default(false)
  verifiedAt DateTime?

  // Settings
  settings Json?

  // Soft delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cafes          Cafe[]
  workerAccounts WorkerAccount[]
  legalDocuments BrandDocument[]
  apiKeys        BrandApiKey[]

  @@map("brands")
}

model Region {
  id        String   @id @default(uuid())
  name      String
  country   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cafes Cafe[]

  @@map("regions")
}

model Cafe {
  id           String    @id @default(uuid())
  name         String
  description  String?
  address      String
  city         String
  street       String?
  latitude     Float
  longitude    Float
  photos       String[]
  rating       Float?    @default(0)
  reviewsCount Int       @default(0)
  brandId      String
  brand        Brand     @relation(fields: [brandId], references: [id])
  regionId     String
  region       Region    @relation(fields: [regionId], references: [id])
  cafeApiUrl   String? // URL к локальному сервису кофейни
  deletedAt    DateTime? // Soft delete
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workerAccounts WorkerAccount[]
  orders         Order[]
  reviews        Review[]
  appointments   Appointment[]

  @@map("cafes")
}

model Order {
  id            String       @id @default(uuid())
  orderNumber   String       @unique
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  cafeId        String
  cafe          Cafe         @relation(fields: [cafeId], references: [id])
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  status        OrderStatus  @default(PENDING)
  totalAmount   Decimal      @db.Decimal(10, 2)

  deliveryType    DeliveryType @default(IN_CAFE)
  deliveryAddress String?
  contactPhone    String?
  notes           String?

  paymentMethod PaymentMethod @default(CARD)

  paidAt             DateTime?
  confirmedAt        DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items        OrderItem[]
  transactions Transaction[]
  review       Review?

  @@index([userId, createdAt])
  @@index([cafeId, status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemName   String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  totalPrice Decimal  @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orderId])
  @@map("order_items")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  cafeId    String
  cafe      Cafe     @relation(fields: [cafeId], references: [id])
  orderId   String?  @unique 
  order     Order?   @relation(fields: [orderId], references: [id])
  
  // Raiting
  rating    Float    // 0.0-5.0 (float для более точного рейтинга)
  comment   String?  // Основной текст отзыва
  
  // Структурированная информация
  pros      String[] // Плюсы (массив строк)
  cons      String[] // Минусы (массив строк)
  
  // Медиа
  photos    String[] // Фото к отзыву (массив URL)
  
  // Модерация
  isVerified Boolean @default(false) // Проверен ли отзыв модератором
  verifiedAt DateTime?
  verifiedBy String? // ID модератора (SYSTEM_ADMIN или BRAND_ADMIN)
  
  // Soft delete
  deletedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cafeId, createdAt])
  @@index([userId, cafeId])
  @@index([orderId])
  @@map("reviews")
}

model Appointment {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  cafeId   String
  cafe     Cafe     @relation(fields: [cafeId], references: [id])
  dateTime DateTime
  duration Int // в минутах
  status   String   @default("pending") // pending, confirmed, cancelled, completed
  qrCode   String?  @unique

  totalAmount   Decimal? @db.Decimal(10, 2)
  paymentMethod String? // "CARD", "BALANCE", "CASH", "FREE"
  transactionId String?

  order Order? @relation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointments")
}

model PaymentCard {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  last4Digits String // Последние 4 цифры (например, "1234")
  cardType    String // "visa", "mastercard", "mir"
  expiryMonth Int // Месяц истечения (1-12)
  expiryYear  Int // Год истечения

  providerToken String? // Токен для повторных платежей (симуляция Stripe токена)

  isDefault  Boolean @default(false)
  isActive   Boolean @default(true)
  holderName String? // Имя держателя карты

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete для карт

  transactions Transaction[]

  @@index([userId, deletedAt])
  @@map("payment_cards")
}

model Transaction {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type   TransactionType
  status TransactionStatus @default(PENDING)

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("RUB")

  orderId String? // Если транзакция связана с заказом
  order   Order?       @relation(fields: [orderId], references: [id])
  cardId  String? // Если использовалась карта
  card    PaymentCard? @relation(fields: [cardId], references: [id])

  provider              String? // "stripe" (симуляция)
  providerTransactionId String? // ID транзакции в системе провайдера (симуляция)

  description String? // Описание транзакции
  metadata    Json? // Дополнительные данные (JSON)

  retryCount Int @default(0) // Количество попыток повторного платежа
  maxRetries Int @default(3) // Максимальное количество попыток

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status])
  @@index([orderId])
  @@map("transactions")
}

model BrandDocument {
  id      String @id @default(uuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  type     DocumentType
  name     String
  fileUrl  String
  fileType String?
  fileSize Int?

  uploadedAt       DateTime  @default(now())
  verifiedAt       DateTime?
  verifiedBy       String?
  isVerified       Boolean   @default(false)
  verificationNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@map("brand_documents")
}

model BrandApiKey {
  id      String @id @default(uuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  name    String
  keyHash String @unique
  prefix  String

  permissions String[]
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([brandId, isActive])
  @@index([keyHash])
  @@map("brand_api_keys")
}

model SystemSettings {
  id        String   @id @default("system")
  settings  Json // JSON объект с настройками
  updatedBy String? // ID SYSTEM_ADMIN, который обновил настройки
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("system_settings")
}
