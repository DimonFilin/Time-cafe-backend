{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "testTimeout": 60000,
  "maxWorkers": 1,
  "forceExit": true,
  "clearMocks": true,
  "setupFilesAfterEnv": ["<rootDir>/setup.ts"],
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": {
          "types": ["jest", "node"]
        }
      }
    ]
  }
}
